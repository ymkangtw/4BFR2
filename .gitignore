# Dependencies
node_modules/
.venv/

# package-lock 不入版控：本機為 Windows，鎖定的平台原生套件（如 rollup）
# 會導致 Render(Linux) 安裝缺對應 binary（npm/cli#4828），故交由佈署端重新解析
package-lock.json
**/package-lock.json

# Environment files
.env
**/.env

# Build output
client/dist/

# Database（佈署沿用本地 r02.db，故放行主檔；journal/wal 仍忽略）
server/data/*.db
!server/data/r02.db
server/data/*.db-journal
server/data/*.db-wal
server/data/*.db-shm

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
